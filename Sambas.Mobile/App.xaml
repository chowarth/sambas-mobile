<?xml version = "1.0" encoding = "UTF-8" ?>
<Application
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Sambas.Mobile"
    x:Class="Sambas.Mobile.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!--
                    Colours.xaml must ALWAYS be at the top as it is referenced
                    by all other style resource dictionaries. If it is not,
                    the app will crash on startup due to missing resources.
                -->
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                
                <ResourceDictionary Source="Resources/Styles/ButtonStyles.xaml" />
                <ResourceDictionary Source="Resources/Styles/DatePickerStyles.xaml" />
                <ResourceDictionary Source="Resources/Styles/EntryStyles.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
                <ResourceDictionary Source="Resources/Styles/SwipeItemStyles.xaml" />
                <ResourceDictionary Source="Resources/Styles/TimePickerStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
