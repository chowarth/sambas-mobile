<?xml version="1.0" encoding="utf-8" ?>
<Border
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:icons="clr-namespace:IconFont.Maui.FluentIcons;assembly=IconFont.Maui.FluentIcons"
    x:Class="Sambas.Mobile.Controls.DatePickerControl"
    x:Name="Self"
    Padding="8"
    Stroke="LightGray"
    StrokeShape="RoundRectangle 8"
    HeightRequest="40">

    <Border.Triggers>
        <DataTrigger
            TargetType="Border"
            Binding="{Binding x:DataType='DatePicker',
                Source={x:Reference DatePicker},
                Path=IsFocused}"
            Value="true">
            <Setter Property="Stroke" Value="{StaticResource Primary}"/>
        </DataTrigger>
    </Border.Triggers>

    <Grid
        ColumnSpacing="8"
        ColumnDefinitions="24,*">
        <Image
            Grid.Row="0"
            Grid.Column="0"
            WidthRequest="24"
            HeightRequest="24"
            VerticalOptions="Center"
            HorizontalOptions="Start"
            Source="{FontImageSource
                Glyph={x:Static icons:FluentIconsRegular.Calendar24},
                FontFamily={x:Static icons:FluentIconsRegular.FontFamily}}"/>
        <DatePicker
            Grid.Row="0"
            Grid.Column="1"
            x:Name="DatePicker"
            Date="{Binding Source={x:Reference Self}, Path=Date}"/>
    </Grid>

</Border>
