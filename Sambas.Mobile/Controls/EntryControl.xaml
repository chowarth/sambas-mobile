<?xml version="1.0" encoding="utf-8" ?>
<Border
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Sambas.Mobile.Controls.EntryControl"
    x:Name="Self"
    Padding="8"
    Stroke="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource DarkText}}"
    StrokeShape="RoundRectangle 8"
    HeightRequest="40">

    <Border.Triggers>
        <DataTrigger
            TargetType="Border"
            Binding="{Binding x:DataType='Entry',
                Source={x:Reference Entry},
                Path=IsFocused}"
            Value="true">
            <Setter Property="Stroke" Value="{StaticResource Primary}"/>
        </DataTrigger>
    </Border.Triggers>

    <Entry
        x:Name="Entry"
        Text="{Binding Source={x:Reference Self}, Path=Text}"
        Keyboard="{Binding Source={x:Reference Self}, Path=Keyboard}"
        IsReadOnly="{Binding Source={x:Reference Self}, Path=IsReadOnly}"/>

</Border>