<?xml version="1.0" encoding="utf-8" ?>
<SwipeItemView
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Sambas.Mobile.Controls.SwipeItemControl"
    x:Name="Self">

    <ImageButton
        Source="{Binding Source={x:Reference Self}, Path=ActionIcon}"
        Aspect="Center"
        BorderColor="{Binding Source={x:Reference Self}, Path=BorderColor}"
        BorderWidth="{Binding Source={x:Reference Self}, Path=BorderWidth}"
        WidthRequest="{Binding Source={x:Reference Self}, Path=WidthRequest}"
        CornerRadius="{Binding Source={x:Reference Self}, Path=CornerRadius}"
        BackgroundColor="{Binding Source={x:Reference Self}, Path=ActionColor}"/>

</SwipeItemView>
