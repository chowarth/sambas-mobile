<?xml version="1.0" encoding="utf-8" ?>
<Border
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:icons="clr-namespace:IconFont.Maui.FluentIcons;assembly=IconFont.Maui.FluentIcons"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    x:Class="Sambas.Mobile.Controls.TimePickerControl"
    x:Name="Self">

    <Border.Resources>
        <ResourceDictionary>
            <toolkit:IsNullConverter x:Key="IsNullConverter" />
            <toolkit:IsNotNullConverter x:Key="IsNotNullConverter" />
        </ResourceDictionary>
    </Border.Resources>

    <Border.Triggers>
        <DataTrigger
            TargetType="Border"
            Binding="{Binding x:DataType='TimePicker',
                Source={x:Reference TimePicker},
                Path=Time,
                Converter={StaticResource IsNullConverter}}"
            Value="true">
            <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource LightTextDanger}, Dark={StaticResource DarkTextDanger}}" />
        </DataTrigger>

        <DataTrigger
            TargetType="Border"
            Binding="{Binding x:DataType='TimePicker',
                Source={x:Reference TimePicker},
                Path=Time,
                Converter={StaticResource IsNotNullConverter}}"
            Value="true">
            <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource LightBorderPrimary}, Dark={StaticResource DarkBorderPrimary}}" />
        </DataTrigger>
    </Border.Triggers>

    <Grid
        ColumnSpacing="8"
        ColumnDefinitions="24,*">
        <Image
            Grid.Row="0"
            Grid.Column="0"
            WidthRequest="24"
            HeightRequest="24"
            VerticalOptions="Center"
            HorizontalOptions="Start"
            Source="{FontImageSource
                Color={AppThemeBinding Light={StaticResource LightTextPrimary}, Dark={StaticResource DarkTextPrimary}},
                Glyph={x:Static icons:FluentIconsRegular.Clock24},
                FontFamily={x:Static icons:FluentIconsRegular.FontFamily}}"/>
        <TimePicker
            Grid.Row="0"
            Grid.Column="1"
            x:Name="TimePicker"
            Time="{Binding Source={x:Reference Self}, Path=Time}"/>
    </Grid>

</Border>
