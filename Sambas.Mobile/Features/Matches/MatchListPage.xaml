<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Sambas.Mobile.Features.Matches"
    x:Class="Sambas.Mobile.Features.Matches.MatchListPage">

    <Grid>
        <CollectionView
            ItemsSource="{Binding Matches}">
            <!-- TODO:
                Empty view
                Group by month
                Swipe to edit?
                Swipe to delete
            -->
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <local:MatchOverview/>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button
            Text="+"
            Margin="16"
            FontSize="24"
            CornerRadius="24"
            WidthRequest="48"
            HeightRequest="48"
            VerticalOptions="End"
            HorizontalOptions="End"
            Command="{Binding AddGameCommand}"/>
    </Grid>
    
</ContentPage>