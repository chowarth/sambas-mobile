<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:Sambas.Mobile.Controls"
    xmlns:icons="clr-namespace:IconFont.Maui.FluentIcons;assembly=IconFont.Maui.FluentIcons"
    xmlns:local="clr-namespace:Sambas.Mobile.Features.Matches"
    x:Class="Sambas.Mobile.Features.Matches.MatchListPage">

    <Grid>
        <CollectionView
            IsGrouped="True"
            ItemsSource="{Binding MatchGroupings}">
            <!-- TODO:
                Empty view
                Swipe to edit
            -->
            <CollectionView.GroupHeaderTemplate>
                <DataTemplate>
                    <ContentView>
                        <Label
                            Margin="16,8"
                            FontAttributes="Bold"
                            Text="{Binding Month, StringFormat= '{0:Y}'}"/>
                    </ContentView>
                </DataTemplate>
            </CollectionView.GroupHeaderTemplate>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <SwipeView Threshold="95">
                        <SwipeView.RightItems>
                            <SwipeItems Mode="Reveal">
                                <controls:SwipeItemControl
                                    Style="{StaticResource DeleteAction}"
                                    Command="{Binding x:DataType='local:MatchListPageViewModel',
                                        Source={RelativeSource AncestorType={x:Type local:MatchListPageViewModel}},
                                        Path=DeleteMatchCommand}"
                                    CommandParameter="{Binding .}"/>
                            </SwipeItems>
                        </SwipeView.RightItems>
                        <local:MatchOverview/>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button
            Text="+"
            Margin="16"
            FontSize="24"
            CornerRadius="24"
            WidthRequest="48"
            HeightRequest="48"
            VerticalOptions="End"
            HorizontalOptions="End"
            Command="{Binding AddMatchCommand}"/>
    </Grid>
    
</ContentPage>