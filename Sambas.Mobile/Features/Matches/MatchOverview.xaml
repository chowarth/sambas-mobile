<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Sambas.Mobile.Features.Matches.MatchOverview">
    <Border
        Margin="16, 8"
        VerticalOptions="Start"
        Style="{StaticResource CardStyle}">
        <Grid
            RowSpacing="8"
            ColumnSpacing="8"
            RowDefinitions="*,*"
            ColumnDefinitions="*,Auto,Auto,Auto,*">
            <Label
                Grid.Row="0"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Text="{Binding KickOff.Date, StringFormat='{0:d}'}"/>
            <Label
                Grid.Row="0"
                Grid.Column="3"
                Grid.ColumnSpan="2"
                Text="{Binding KickOff.Time, StringFormat='{0:hh\\:mm}'}"
                HorizontalTextAlignment="End"/>

            <Label
                Grid.Row="1"
                Grid.Column="0"
                Style="{StaticResource LabelSemibold}"
                Text="{Binding HomeTeam.Name}"
                VerticalOptions="Center"/>
            <Label
                Grid.Row="1"
                Grid.Column="1"
                Text="{Binding Score.HomeTeamScore}"
                FontSize="20"
                Style="{StaticResource LabelSemibold}"
                VerticalOptions="Center"/>
            
            <Label
                Grid.Row="1"
                Grid.Column="2"
                Text="-"
                Style="{StaticResource LabelSemibold}"
                VerticalOptions="Center"/>
            
            <Label
                Grid.Row="1"
                Grid.Column="3"
                Text="{Binding Score.AwayTeamScore}"
                FontSize="20"
                Style="{StaticResource LabelSemibold}"
                VerticalOptions="Center"/>
            <Label
                Grid.Row="1"
                Grid.Column="4"
                Style="{StaticResource LabelSemibold}"
                Text="{Binding AwayTeam.Name}"
                VerticalOptions="Center"
                HorizontalTextAlignment="End"/>
        </Grid>
    </Border>
</ContentView>
