<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Sambas.Mobile.Features.SelectTeam.SelectTeamPage"
    Title="Select Team"
    Shell.NavBarIsVisible="False">

    <Grid>
        <VerticalStackLayout
            BindableLayout.ItemsSource="{Binding Teams}"
            BindableLayout.EmptyView="Add a team...">
            <BindableLayout.ItemTemplate>
                <DataTemplate>
                    <Border
                        Style="{StaticResource CardStyle}">
                        <Grid
                            ColumnSpacing="16"
                            ColumnDefinitions="Auto, *">
                            <Image
                                Grid.Column="0"
                                Source="{Binding LogoUrl}"
                                WidthRequest="50"
                                HeightRequest="50"
                                Aspect="AspectFit"
                                VerticalOptions="Center"/>
                            <Label
                                Grid.Column="1"
                                Text="{Binding Name}"
                                FontSize="Title"
                                VerticalOptions="Center"
                                VerticalTextAlignment="Center"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </BindableLayout.ItemTemplate>
        </VerticalStackLayout>
        <Button
            Text="+"
            Margin="16"
            FontSize="24"
            CornerRadius="24"
            WidthRequest="48"
            HeightRequest="48"
            VerticalOptions="End"
            HorizontalOptions="End"/>
    </Grid>
    
</ContentPage>