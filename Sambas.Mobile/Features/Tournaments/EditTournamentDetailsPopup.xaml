<?xml version="1.0" encoding="utf-8" ?>
<uxd:PopupResultPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:controls="clr-namespace:Sambas.Mobile.Controls"
    xmlns:i18n="clr-namespace:Sambas.Mobile.Resources.Localisation"
    xmlns:models="clr-namespace:Sambas.Mobile.Models"
    xmlns:uxd="clr-namespace:UXDivers.Popups.Maui;assembly=UXDivers.Popups.Maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Sambas.Mobile.Features.Tournaments.EditTournamentDetailsPopup"
    x:TypeArguments="models:Tournament"
    Result="{Binding Tournament}">

    <Border
        VerticalOptions="Start"
        Style="{StaticResource CardStyle}">
        <VerticalStackLayout>
            <Label
                Text="{x:Static i18n:Strings.TournamentDetails_Title}"
                FontSize="18"
                Style="{StaticResource LabelSemibold}"/>
            <BoxView
                Style="{StaticResource Separator}"/>
            <Label
                Text="{x:Static i18n:Strings.NameLabel}"
                FontSize="14"
                TextTransform="Uppercase"/>
            <controls:EntryControl
                Text="{Binding TournamentName}"/>
            <Label
                Text="{x:Static i18n:Strings.StartDateLabel}"
                FontSize="14"
                TextTransform="Uppercase"/>
            <controls:DatePickerControl
                Date="{Binding StartDate}"/>
            <Label
                Text="{x:Static i18n:Strings.EndDateLabel}"
                FontSize="14"
                TextTransform="Uppercase"/>
            <controls:DatePickerControl
                Date="{Binding EndDate}"/>

            <Button
                Text="{x:Static i18n:Strings.SaveButton}"
                VerticalOptions="End"
                Command="{Binding SaveTournamentCommand}"
                IsEnabled="{Binding IsValid}"/>
        </VerticalStackLayout>
    </Border>

</uxd:PopupResultPage>
