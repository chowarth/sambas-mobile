<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Note: For Android please see also Platforms\Android\Resources\values\colors.xml -->

    <Color x:Key="Primary">#2E7B2B</Color>
    <Color x:Key="PopupBackground">#BF000000</Color>
    
    <!-- Light mode -->
    <Color x:Key="LightText">#000000</Color>
    <Color x:Key="LightBackground">#F0F0F0</Color>
    <Color x:Key="LightBackgroundAlt">#E1E1E1</Color>
    <Color x:Key="LightCardBackground">#FFFFFF</Color>
    <Color x:Key="LightSuccess">#1B7F5C</Color>
    <Color x:Key="LightWarning">#B8871F</Color>
    <Color x:Key="LightDanger">#B13535</Color>
    <Color x:Key="LightInfo">#1E56A3</Color>

    <!-- Dark mode -->
    <Color x:Key="DarkText">#FFFFFF</Color>
    <Color x:Key="DarkBackground">#282828</Color>
    <Color x:Key="DarkBackgroundAlt">#3F3F3F</Color>
    <Color x:Key="DarkCardBackground">#121212</Color>
    <Color x:Key="DarkSuccess">#22946E</Color>
    <Color x:Key="DarkWarning">#A87A2A</Color>
    <Color x:Key="DarkDanger">#9C2121</Color>
    <Color x:Key="DarkInfo">#21498A</Color>

</ResourceDictionary>